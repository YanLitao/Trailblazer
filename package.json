{
  "name": "trailblazer",
  "displayName": "Trailblazer",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.91.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trailblazer.askQuestion",
        "title": "Ask Trailblazer a question"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trailblazer-sidebar",
          "title": "Trailblazer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "trailblazer-sidebar": [
        {
          "type": "webview",
          "id": "trailblazer.sidebarView",
          "name": "Exploration",
          "icon": "resources/icon.svg"
        }
      ]
    }
  },
  "assets": {
    "media": [
      "media/sidebar.css",
      "media/sidebar.js"
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@langchain/core": "^0.2.27",
    "@langchain/openai": "^0.2.7",
    "langchain": "^0.2.16"
  }
}